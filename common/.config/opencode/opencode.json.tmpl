{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "lsp": true,
  "model": "dynamic/model",
  "small_model": "dynamic/small_model",
  "provider": {
    "venice": {
      "models": {
        "olafangensan-glm-4.7-flash-heretic": {
          "limit": {
            "context": 128000,
            "output": 24000
          }
        }
      }
    }
  },
  "agent": {
    "plan": {
      "model": "dynamic/frontier_model",
      "permissions": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "build": {
      "model": "dynamic/model"
    },
    "general": {
      "model": "dynamic/model"
    },
    "explore": {
      "model": "dynamic/small_model"
    },
    "scout": {
      "model": "dynamic/small_model"
    },
    "review": {
      "description": "Read-only code review, caveman terse output",
      "mode": "primary",
      "model": "dynamic/antagonist_model",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        }
      }
    },
    "compaction": {
      "model": "dynamic/small_model"
    },
    "title": {
      "model": "dynamic/small_model"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@3.1.13"
  ]
}
