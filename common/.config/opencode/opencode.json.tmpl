{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "lsp": true,
  "model": "dynamic/model",
  "small_model": "dynamic/small_model",
  "provider": {
    "venice": {
      "models": {
        "olafangensan-glm-4.7-flash-heretic": {
          "limit": {
            "context": 128000,
            "output": 24000
          }
        }
      }
    },
    "amazon-bedrock": {
      "options": {
        "region": "us-west-2",
        "profile": "claude-code-bedrock-sso"
      },
      "models": {
        "claude-opus": {
          "id": "arn:aws:bedrock:us-west-2:168134825737:application-inference-profile/a4v3qtnkelgp",
          "name": "Claude Opus (Bedrock)"
        },
        "claude-sonnet": {
          "id": "arn:aws:bedrock:us-west-2:168134825737:application-inference-profile/i85wjhfzw5r3",
          "name": "Claude Sonnet (Bedrock)"
        },
        "claude-haiku": {
          "id": "arn:aws:bedrock:us-west-2:168134825737:application-inference-profile/u8agk44ql7te",
          "name": "Claude Haiku (Bedrock)"
        }
      }
    }
  },
  "agent": {
    "plan": {
      "model": "dynamic/frontier_model",
      "prompt": "{file:agents/plan.txt}",
      "permission": {
        "edit": "ask",
        "bash": "ask"
      }
    },
    "build": {
      "model": "dynamic/model"
    },
    "general": {
      "model": "dynamic/model"
    },
    "explore": {
      "model": "dynamic/small_model",
      "prompt": "{file:agents/explore.txt}"
    },
    "scout": {
      "model": "dynamic/small_model"
    },
    "review": {
      "description": "Read-only code review, caveman terse output",
      "mode": "primary",
      "model": "dynamic/antagonist_model",
      "prompt": "{file:agents/review.txt}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "gh issue view*": "allow",
          "gh pr view*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow",
          "rg *": "allow",
          "grep *": "allow"
        }
      }
    },
    "compaction": {
      "model": "dynamic/small_model"
    },
    "title": {
      "model": "dynamic/small_model"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@3.1.13",
    "opencode-hashline@1.4.0"
  ]
}
