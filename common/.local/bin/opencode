#!/bin/bash

find_opencode_cli() {
    local paths=(
        "$HOME/.opencode/bin/opencode"
        "/opt/homebrew/bin/opencode"
        "/usr/local/bin/opencode"
    )
    for path in "${paths[@]}"; do
        if [[ -x "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    return 1
}

OPENCODE_CLI=$(find_opencode_cli)

if [[ -z "$OPENCODE_CLI" ]]; then
    echo "Error: opencode binary not found" >&2
    exit 1
fi

has_desktop_app() {
    mdfind 'kMDItemCFBundleIdentifier == "ai.opencode.desktop"' 2>/dev/null | grep -q .
}

is_cli_mode() {
    for arg in "$@"; do
        case "$arg" in
            --help|-h|--version|-V|update|install|uninstall|config|provider|model|mcp|auth|agent|project|session|file|find|event|tui)
                return 0
                ;;
        esac
    done
    return 1
}

if has_desktop_app && ! is_cli_mode "$@"; then
    dir="${1:-$(pwd)}"
    if [[ -d "$dir" ]] || [[ "$dir" == /* ]]; then
        open "opencode://open-project?directory=$dir"
        exit 0
    fi
fi

exec "$OPENCODE_CLI" "$@"
