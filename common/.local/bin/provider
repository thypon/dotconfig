#!/usr/bin/env python3
# Resolve dynamic-models.jsonc provider into opencode.json + pi settings.json
# Usage: provider <prefix>
#   Fuzzy-matches provider name by first letters (e.g. "a" -> "anthropic")
#   Resolves dynamic/* tokens in template files and commands/prompts.

import json
import re
import sys
import os
import shutil


def find_repo_root():
    """Walk up from this script's real path to find the git repo root."""
    path = os.path.realpath(__file__)
    path = os.path.dirname(path)
    while path != "/":
        if os.path.isdir(os.path.join(path, ".git")):
            return path
        path = os.path.dirname(path)
    sys.exit("error: cannot find repo root")


REPO_ROOT = find_repo_root()

# Shared models (single source of truth)
MODELS_PATH = os.path.expanduser("~/.config/dynamic-models.jsonc")

# OpenCode paths
TEMPLATE_PATH = os.path.expanduser("~/.config/opencode/opencode.json.tmpl")
OUTPUT_PATH = os.path.expanduser("~/.config/opencode/opencode.json")
COMMANDS_SRC = os.path.join(REPO_ROOT, "common", ".config", "opencode", "commands")
COMMANDS_DST = os.path.expanduser("~/.config/opencode/commands")
OPENCODE_CONFIG_DIR = os.path.expanduser("~/.config/opencode")

# pi paths
PI_CONFIG_SRC = os.path.join(REPO_ROOT, "common", ".config", "pi")
PI_CONFIG_LINK = os.path.expanduser("~/.config/pi")
PI_SETTINGS_TMPL = os.path.join(PI_CONFIG_SRC, "settings.json.tmpl")
PI_SETTINGS_DST = os.path.expanduser("~/.pi/agent/settings.json")
PI_PROMPTS_SRC = os.path.join(PI_CONFIG_SRC, "prompts")
PI_PROMPTS_DST = os.path.expanduser("~/.pi/agent/prompts")
PI_SKILLS_DST = os.path.expanduser("~/.pi/agent/skills")
PI_EXTENSIONS_DST = os.path.expanduser("~/.pi/agent/extensions")
PI_EXTENSIONS_SRC = os.path.join(PI_CONFIG_SRC, "extensions")
SHARED_SKILLS = os.path.join(REPO_ROOT, "common", ".config", "skills")
OPENCODE_SKILLS = os.path.expanduser("~/.config/opencode/skills")


def strip_jsonc_comments(text):
    """Remove // and /* */ comments from JSONC, preserving strings."""
    pattern = r'"(?:[^"\\]|\\.)*"|//.*?$|/\*.*?\*/'
    def replacer(m):
        s = m.group(0)
        if s.startswith('"'):
            return s
        return ''
    return re.sub(pattern, replacer, text, flags=re.MULTILINE | re.DOTALL)


def load_jsonc(path):
    with open(path) as f:
        return json.loads(strip_jsonc_comments(f.read()))


def match_provider(providers, prefix):
    """Match provider by prefix. Returns (name, config) or exits with error."""
    prefix = prefix.lower()
    matches = [(k, v) for k, v in providers.items() if k.lower().startswith(prefix)]
    if len(matches) == 1:
        return matches[0]
    if len(matches) == 0:
        print(f"error: no provider matching '{prefix}'", file=sys.stderr)
        print(f"available: {', '.join(sorted(providers.keys()))}", file=sys.stderr)
        sys.exit(1)
    names = [m[0] for m in matches]
    print(f"error: ambiguous prefix '{prefix}' matches: {', '.join(names)}", file=sys.stderr)
    sys.exit(1)


def make_replacements(provider_config):
    return {
        "dynamic/provider": provider_config.get("name", ""),
        "dynamic/model": provider_config["model"],
        "dynamic/small_model": provider_config["small_model"],
        "dynamic/frontier_model": provider_config["frontier_model"],
        "dynamic/antagonist_model": provider_config["antagonist_model"],
    }


def resolve_template(template, replacements):
    """Recursively replace string values that exactly match replacement keys."""
    def replace_in_obj(obj):
        if isinstance(obj, str):
            return replacements.get(obj, obj)
        if isinstance(obj, list):
            return [replace_in_obj(item) for item in obj]
        if isinstance(obj, dict):
            return {k: replace_in_obj(v) for k, v in obj.items()}
        return obj
    return replace_in_obj(template)


def resolve_text(text, replacements):
    """Replace all dynamic/* tokens in a plain text string."""
    for key, value in replacements.items():
        text = text.replace(key, value)
    return text


def ensure_dir(path):
    os.makedirs(path, exist_ok=True)


def ensure_symlink(target, link):
    """Create symlink if not exists. Replace wrong symlink or real dir."""
    if os.path.realpath(target) == os.path.realpath(link):
        return
    if os.path.islink(link):
        current = os.readlink(link)
        if current == target:
            return
        os.unlink(link)
    elif os.path.isdir(link):
        shutil.rmtree(link)
    elif os.path.exists(link):
        os.unlink(link)
    os.symlink(target, link)
    print(f"  linked: {link} -> {target}")


def resolve_and_copy(dir_src, dir_dst, replacements):
    """Copy dir_src to dir_dst, resolving dynamic/* tokens in all files."""
    if not os.path.isdir(dir_src):
        print(f"warning: source dir not found: {dir_src}", file=sys.stderr)
        return
    ensure_dir(dir_dst)
    for entry in os.listdir(dir_src):
        src = os.path.join(dir_src, entry)
        dst = os.path.join(dir_dst, entry)
        if os.path.isdir(src):
            resolve_and_copy(src, dst, replacements)
        else:
            if os.path.islink(dst):
                os.unlink(dst)
            with open(src) as f:
                content = f.read()
            resolved = resolve_text(content, replacements)
            with open(dst, "w") as f:
                f.write(resolved)
            print(f"  resolved: {dst}")


def setup_opencode(replacements):
    """Resolve opencode.json template and copy commands."""
    if not os.path.exists(TEMPLATE_PATH):
        print("warning: opencode.json.tmpl not found, skipping opencode setup", file=sys.stderr)
        return

    template = load_jsonc(TEMPLATE_PATH)
    result = resolve_template(template, replacements)

    with open(OUTPUT_PATH, "w") as f:
        json.dump(result, f, indent=2)
        f.write("\n")
    print(f"  resolved: {OUTPUT_PATH}")

    resolve_and_copy(COMMANDS_SRC, COMMANDS_DST, replacements)

    # Ensure skills symlink to shared
    ensure_symlink(SHARED_SKILLS, OPENCODE_SKILLS)


def setup_pi(replacements):
    """Resolve pi settings.json template, copy prompts, set up symlinks."""
    # Ensure ~/.config/pi symlink to repo
    ensure_symlink(PI_CONFIG_SRC, PI_CONFIG_LINK)

    if not os.path.exists(PI_SETTINGS_TMPL):
        print("warning: pi settings.json.tmpl not found, skipping pi setup", file=sys.stderr)
        return

    template = load_jsonc(PI_SETTINGS_TMPL)
    result = resolve_template(template, replacements)

    ensure_dir(os.path.dirname(PI_SETTINGS_DST))
    with open(PI_SETTINGS_DST, "w") as f:
        json.dump(result, f, indent=2)
        f.write("\n")
    print(f"  resolved: {PI_SETTINGS_DST}")

    resolve_and_copy(PI_PROMPTS_SRC, PI_PROMPTS_DST, replacements)

    # Symlink skills → shared
    ensure_symlink(SHARED_SKILLS, PI_SKILLS_DST)

    # Symlink extensions → ~/.config/pi/extensions (which is repo symlink)
    ensure_symlink(PI_EXTENSIONS_SRC, PI_EXTENSIONS_DST)


def main():
    if len(sys.argv) < 2:
        # Just ensure symlinks without provider resolution
        ensure_symlink(SHARED_SKILLS, OPENCODE_SKILLS)
        if os.path.exists(PI_CONFIG_SRC):
            ensure_symlink(PI_CONFIG_SRC, PI_CONFIG_LINK)
            ensure_symlink(SHARED_SKILLS, PI_SKILLS_DST)
            ensure_symlink(PI_EXTENSIONS_SRC, PI_EXTENSIONS_DST)

        try:
            models = load_jsonc(MODELS_PATH)
        except FileNotFoundError:
            print("error: dynamic-models.jsonc not found. Create symlink:", file=sys.stderr)
            print("  ln -s REPO/common/.config/dynamic-models.jsonc ~/.config/dynamic-models.jsonc", file=sys.stderr)
            sys.exit(1)

        providers = models["providers"]
        print(f"usage: provider <prefix>", file=sys.stderr)
        print(f"available: {', '.join(sorted(providers.keys()))}", file=sys.stderr)
        print(f"\nsymlinks created. Run with provider prefix to resolve templates.", file=sys.stderr)
        sys.exit(1)

    prefix = sys.argv[1]

    # Ensure shared models symlink exists
    if not os.path.exists(MODELS_PATH):
        models_repo = os.path.join(REPO_ROOT, "common", ".config", "dynamic-models.jsonc")
        if os.path.exists(models_repo):
            ensure_symlink(models_repo, MODELS_PATH)

    models = load_jsonc(MODELS_PATH)
    providers = models["providers"]
    name, config = match_provider(providers, prefix)
    config["name"] = name
    replacements = make_replacements(config)

    print(f"--- opencode ---")
    setup_opencode(replacements)

    print(f"\n--- pi ---")
    setup_pi(replacements)

    print(f"\n{name}: model={config['model']} small={config['small_model']} frontier={config['frontier_model']} antagonist={config['antagonist_model']}")


if __name__ == "__main__":
    main()
