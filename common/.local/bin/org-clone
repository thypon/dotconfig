#!/bin/sh
set -eu
# Clone all repos from a GitHub organisation
# Usage: org-clone [git-clone-flags...] <org>
last="${@: -1}"
set -- "${@:1:$(($#-1))}"

gh repo list "$last" --no-archived --limit 9999 --json name,visibility \
	| jq -r '.[] | "\(.name):\(.visibility)"' \
	| while IFS= read -r entry; do
		name="${entry%%:*}"
		visibility="${entry##*:}"
		case "$visibility" in
			PRIVATE)  dir="private/$name" ;;
			INTERNAL) dir="internal/$name" ;;
			*)        dir="$name" ;;
		esac
		if [ -d "$dir" ]; then
			echo "Pulling $last/$name ($visibility)..."
			git -C "$dir" pull
		else
			echo "Cloning $last/$name ($visibility)..."
			mkdir -p "$(dirname "$dir")"
			gh repo clone "$last/$name" "$dir"
		fi
	done