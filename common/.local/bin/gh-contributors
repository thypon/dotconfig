#!/bin/sh
set -eu
# List GitHub nicknames of contributors across repositories
# Usage: gh-contributors [days] [directory...]
#   days:        number of days to look back (default: 365)
#   directory:   one or more paths to git repositories (default: .)
days="${1:-365}"
shift 2>/dev/null || true

since=$(date -v-"${days}"d +%Y-%m-%d 2>/dev/null || date -d "$days days ago" +%Y-%m-%d)

if [ $# -eq 0 ]; then
	set -- .
fi

resolve_email() {
	email="$1"
	nwo="$2"
	# Extract login from GitHub noreply emails
	case "$email" in
		*+*@users.noreply.github.com)
			echo "$email" | sed 's/^[0-9]*+//;s/@users\.noreply\.github\.com$//'
			return ;;
		*@users.noreply.github.com)
			echo "$email" | sed 's/@users\.noreply\.github\.com$//'
			return ;;
	esac
	# Resolve via repo commits API (handles private emails)
	while :; do
		if login=$(gh api "/repos/$nwo/commits?per_page=1&author=$email" --jq '.[0].author.login // empty' 2>/dev/null); then
			if [ -n "$login" ]; then
				echo "$login"
			else
				echo "$email"
			fi
			return
		fi
		echo "Rate limited, waiting 60s..." >&2
		sleep 60
	done
}

# Collect email:nwo pairs, keeping first repo seen per email
seen_emails=""
for dir in "$@"; do
	nwo=$(git -C "$dir" remote get-url origin 2>/dev/null \
		| sed 's|.*github\.com[:/]||;s|\.git$||') || continue
	[ -z "$nwo" ] && continue
	for email in $(git -C "$dir" log --since="$since" --format='%ae' | sort -u); do
		case "$seen_emails" in
			*"$email"*) continue ;;
		esac
		seen_emails="$seen_emails $email"
		resolve_email "$email" "$nwo"
	done
done \
	| sort -uf
